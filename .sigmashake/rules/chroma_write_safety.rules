# chroma_write_safety.rules
# Technology: chroma | Capability: write

rule chroma-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_chroma_PATTERN"
  MESSAGE "Blocked an unsafe pattern in chroma. Use the recommended best practices for 2025/2026."
}

rule chroma-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_chroma_API"
  MESSAGE "You are using an outdated API for chroma. Please upgrade to the newer API."
}
